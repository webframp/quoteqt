# Honeycomb API key for OpenTelemetry tracing
# Get your key from https://ui.honeycomb.io/account
# HONEYCOMB_API_KEY=your-api-key-here

# Optional: Override the service name (default: quotes)
# OTEL_SERVICE_NAME=quotes

# Admin emails (comma-separated) - these users have full access
# ADMIN_EMAILS=admin@example.com,other@example.com

# Nightbot OAuth - for backup/restore feature
# Register at https://nightbot.tv/account/applications
# NIGHTBOT_CLIENT_ID=
# NIGHTBOT_CLIENT_SECRET=
# NIGHTBOT_IMPORT_TOKEN=random-secret-for-tampermonkey-imports
# NIGHTBOT_SESSION_KEY=random-secret-for-managed-channel-encryption

# Twitch OAuth - for moderator authentication
# Register at https://dev.twitch.tv/console/apps
# Redirect URL: https://yourdomain.com/auth/twitch/callback
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=

# Session secret for signing cookies (auto-generated if not set)
# Set explicitly for persistence across restarts
# SESSION_SECRET=
